# Скопируйте этот файл в .env и заполните значения
# Ключ Anthropic API — получить на https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-ваш-ключ-здесь

# Домен вашего сайта на Тильде (можно несколько через запятую)
# Например: https://kadrovye-rezervy.ru,https://kadrovye-rezervy.tilda.ws
ALLOWED_ORIGIN=*

PORT=3000

# Необязательно: уведомления о новых лидах в Telegram (в тот же бот, что вы уже разворачивали)
# Токен бота — от @BotFather, chat_id — id вашего чата/канала, куда слать уведомления
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

